# API Keys (optional - system will use synthetic data if not provided)
YAHOO_FINANCE_API_KEY=
ALPHA_VANTAGE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
NEWS_API_KEY=
OPENROUTER_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# -------------------------------------------
# Data Settings
# -------------------------------------------

# SET TO 'false' BECAUSE YOU NOW HAVE REAL API KEYS
USE_SYNTHETIC_DATA=false

# Directory to store cached data files
DATA_CACHE_DIR=./data/cache

# -------------------------------------------
# LLM Settings
# -------------------------------------------

# SET TO 'true' TO USE OPENROUTER/LLAMA
USE_LLM_SENTIMENT=true

# -------------------------------------------
# Model Settings
# -------------------------------------------

RANDOM_SEED=42
DEVICE=cpu

# -------------------------------------------
# Federated Learning Settings
# -------------------------------------------

NUM_CLIENTS=10
LOCAL_EPOCHS=10
FEDERATED_ROUNDS=100
LEARNING_RATE=0.0005
LOCAL_BATCH_SIZE=32

# -------------------------------------------
# Dashboard Settings
# -------------------------------------------

STREAMLIT_PORT=8501